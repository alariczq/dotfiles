#!/usr/bin/env zsh
set -uo pipefail

DOTFILES="${0:a:h}"
PRESELECT=(mise zsh)

# -- colors ----------------------------------------------------------------

bold=$'\033[1m'  dim=$'\033[2m'  reset=$'\033[0m'
green=$'\033[32m'  yellow=$'\033[33m'  cyan=$'\033[36m'

# -- discover stow packages -----------------------------------------------

packages=()
for d in "$DOTFILES"/*(N/); do
  local name="${d:t}"
  [[ $name == .* ]] && continue
  packages+=("$name")
done

if (( ${#packages} == 0 )); then
  echo "No packages found in $DOTFILES"
  exit 1
fi

# -- detect already-installed packages -------------------------------------

is_stowed() {
  local pkg=$1
  local pkgdir="$DOTFILES/$pkg"
  local queue=("$pkgdir") dir entry target link
  while (( ${#queue} )); do
    dir=$queue[1]; shift queue
    for entry in "$dir"/*(DN) "$dir"/.*(DN); do
      [[ ${entry:t} == (.|..) ]] && continue
      target="$HOME/${entry#$pkgdir/}"
      if [[ -L $target ]]; then
        link=${target:A}
        [[ $link == $DOTFILES/$pkg/* ]] && return 0
      elif [[ -d $entry && -d $target ]]; then
        queue+=("$entry")
      fi
    done
  done
  return 1
}

installed=()
for p in $packages; do
  if is_stowed "$p"; then
    installed+=(1)
  else
    installed+=(0)
  fi
done

# -- initial selection (parallel array) ------------------------------------

selected=()
for i in {1..${#packages}}; do
  if (( installed[$i] )) || (( ${PRESELECT[(Ie)$packages[$i]]} )); then
    selected+=(1)
  else
    selected+=(0)
  fi
done

# -- interactive picker ----------------------------------------------------

local cursor=1
local total=${#packages}
local drawn=0

draw() {
  if (( drawn )); then
    printf '\033[%dA' "$((total + 2))"
  fi
  drawn=1

  printf "${bold}Select packages to manage (space=toggle, enter=confirm):${reset}\n"
  for i in {1..$total}; do
    local name="$packages[$i]"
    local arrow=" "
    (( i == cursor )) && arrow=">"
    local mark="${dim}[ ]${reset}"
    (( selected[$i] )) && mark="${green}[x]${reset}"
    local suffix=""
    (( installed[$i] )) && suffix=" ${dim}(installed)${reset}"
    printf " ${cyan}%s${reset} %b %s%b\n" "$arrow" "$mark" "$name" "$suffix"
  done
  printf "${dim}  (a=all, n=none, q=quit)${reset}\n"
}

pick() {
  printf '\033[?25l'
  trap 'printf "\033[?25h"' EXIT INT TERM

  draw
  while true; do
    local key=""
    read -rsk1 key
    case "$key" in
      k)
        (( cursor > 1 )) && (( cursor-- ))
        ;;
      j)
        (( cursor < total )) && (( cursor++ ))
        ;;
      ' ')
        (( selected[$cursor] = !selected[$cursor] ))
        ;;
      a)
        for i in {1..$total}; do selected[$i]=1; done
        ;;
      n)
        for i in {1..$total}; do selected[$i]=0; done
        ;;
      q)
        printf '\033[?25h'
        echo ""
        echo "Cancelled."
        exit 0
        ;;
      $'\n')
        break
        ;;
      $'\e')
        local seq1="" seq2=""
        read -rsk1 -t 0.01 seq1 2>/dev/null || true
        read -rsk1 -t 0.01 seq2 2>/dev/null || true
        case "$seq2" in
          A) (( cursor > 1 )) && (( cursor-- )) ;;
          B) (( cursor < total )) && (( cursor++ )) ;;
        esac
        ;;
    esac
    draw
  done

  printf '\033[?25h'
}

pick

# -- compute actions -------------------------------------------------------

to_install=()
to_remove=()
for i in {1..$total}; do
  local p="$packages[$i]"
  if (( selected[$i] && !installed[$i] )); then
    to_install+=("$p")
  elif (( !selected[$i] && installed[$i] )); then
    to_remove+=("$p")
  fi
done

if (( ${#to_install} == 0 && ${#to_remove} == 0 )); then
  echo ""
  echo "Nothing changed."
  exit 0
fi

echo ""
(( ${#to_install} )) && printf "${bold}Install:${reset} %s\n" "${to_install[*]}"
(( ${#to_remove} ))  && printf "${bold}Remove:${reset}  %s\n" "${to_remove[*]}"
echo ""

# -- ensure stow -----------------------------------------------------------

ensure_stow() {
  command -v stow &>/dev/null && return
  echo "stow not found, installing..."
  if command -v brew &>/dev/null; then
    brew install stow
  elif command -v apt-get &>/dev/null; then
    sudo apt-get install -y stow
  elif command -v pacman &>/dev/null; then
    sudo pacman -S --noconfirm stow
  else
    echo "Error: cannot install stow automatically. Install it manually and re-run."
    exit 1
  fi
}

ensure_stow

# -- ensure mise (if installing) -------------------------------------------

if (( ${to_install[(Ie)mise]} )); then
  if ! command -v mise &>/dev/null; then
    echo "mise not found, installing..."
    curl -fsSL https://mise.jdx.dev/install.sh | sh
  fi
fi

# -- unstow ----------------------------------------------------------------

for p in $to_remove; do
  printf "  unstow ${cyan}%s${reset}" "$p"
  if stow -d "$DOTFILES" -t "$HOME" -D "$p" 2>&1; then
    printf " ${green}ok${reset}\n"
  else
    printf " ${yellow}failed${reset}\n"
  fi
done

# -- stow ------------------------------------------------------------------

for p in $to_install; do
  printf "  stow ${cyan}%s${reset}" "$p"
  if stow -d "$DOTFILES" -t "$HOME" --no-folding "$p" 2>&1; then
    printf " ${green}ok${reset}\n"
  else
    printf " ${yellow}conflict (--adopt to overwrite)${reset}\n"
  fi
done

# -- post-install ----------------------------------------------------------

if (( ${to_install[(Ie)mise]} )); then
  echo ""
  echo "Running mise install..."
  mise install --yes 2>&1 | tail -5
fi

echo ""
printf "${green}${bold}Done.${reset}"
if (( ${to_install[(Ie)zsh]} )); then
  printf " Restart your shell or run: ${cyan}exec zsh -l${reset}"
fi
echo ""

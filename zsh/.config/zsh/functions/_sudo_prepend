if [[ -z $BUFFER ]]; then
  zle up-history
  [[ -z $BUFFER ]] && return
  [[ $BUFFER == sudo\ * ]] || BUFFER="sudo $BUFFER"
  CURSOR=$#BUFFER
elif [[ $BUFFER == sudo\ * ]]; then
  BUFFER="${BUFFER#sudo }"
  (( CURSOR = CURSOR > 5 ? CURSOR - 5 : 0 ))
else
  BUFFER="sudo $BUFFER"
  (( CURSOR += 5 ))
fi

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 7,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet",
    "BASH_DEFAULT_TIMEOUT_MS": "300000"
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "mcp__ide",
      "mcp__plugin_context7_context7",
      "Bash(go:*)",
      "Bash(cargo:*)",
      "Bash(python3:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker images:*)",
      "Bash(docker inspect:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm install:*)",
      "Bash(npx tsc:*)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(gh repo view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh api:*)",
      "Bash(dhsctl:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(cargo publish:*)",
      "Bash(npm publish:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(~/.ssh/*)",
      "Read(~/.gnupg/*)",
      "Read(~/.aws/*)",
      "Read(~/.kube/*)",
      "Read(~/.config/gh/*)",
      "Read(~/.config/gcloud/*)",
      "Read(~/.docker/config.json)",
      "Read(~/.git-credentials)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.local/cargo/credentials.toml)",
      "Read(~/.zsh_history)",
      "Read(~/.bash_history)",
      "Read(~/Library/Keychains/*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opusplan",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alaric/.local/go/bin/comment-checker"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "ast-grep@ast-grep-marketplace": true
  },
  "extraKnownMarketplaces": {
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "network": {
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "~/.local/go/pkg/mod",
        "~/Library/Caches/go-build",
        "~/.local/cargo/registry",
        "~/.local/cargo/git",
        "~/.npm"
      ],
      "denyWrite": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.kube",
        "~/.config/gh"
      ],
      "denyRead": [
        ".env",
        ".env.*",
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.kube",
        "~/.docker/config.json",
        "~/.config/gh",
        "~/.config/gcloud",
        "~/.git-credentials",
        "~/.netrc",
        "~/.npmrc",
        "~/.pypirc",
        "~/.local/cargo/credentials.toml",
        "~/.zsh_history",
        "~/.bash_history",
        "~/.node_repl_history",
        "~/.python_history",
        "~/Library/Keychains"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "docker",
      "gh",
      "go",
      "cargo",
      "npm",
      "npx",
      "python3"
    ]
  },
  "plansDirectory": ".claude/plans",
  "autoMemoryEnabled": true,
  "effortLevel": "medium"
}

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_NEW_INIT": "true",
    "CLAUDE_CODE_RESUME_INTERRUPTED_TURN": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(which *)",
      "Bash(whoami)",
      "Bash(uname *)",
      "Bash(date *)",
      "Bash(date)",
      "Bash(hostname)",
      "Bash(id)",
      "Bash(uptime)",
      "Bash(pwd)",
      "Bash(env)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(diff *)",
      "Bash(xargs *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(ps *)",
      "Bash(pgrep *)",
      "Bash(lsof *)",
      "Bash(tree *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(sha256sum *)",
      "Bash(md5 *)",
      "Bash(base64 *)",
      "Bash(go *)",
      "Bash(cargo *)",
      "Bash(python3 *)",
      "Bash(node *)",
      "Bash(make *)",
      "Bash(cmake *)",
      "Bash(gcc *)",
      "Bash(g++ *)",
      "Bash(clang *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)",
      "Bash(docker images *)",
      "Bash(docker inspect *)",
      "Bash(docker compose *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(bun *)",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git branch)",
      "Bash(git tag *)",
      "Bash(git stash *)",
      "Bash(git blame *)",
      "Bash(git rev-parse *)",
      "Bash(git remote -v)",
      "Bash(git ls-files *)",
      "Bash(gh repo view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh api *)",
      "Bash(dhsctl *)",
      "mcp__ide",
      "mcp__plugin_context7_context7"
    ],
    "deny": [
      "Bash(git reset --hard *)",
      "Bash(cargo publish *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(~/.ssh/*)",
      "Read(~/.gnupg/*)",
      "Read(~/.aws/*)",
      "Read(~/.kube/*)",
      "Read(~/.config/gh/*)",
      "Read(~/.config/gcloud/*)",
      "Read(~/.docker/config.json)",
      "Read(~/.git-credentials)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.local/cargo/credentials.toml)",
      "Read(~/.zsh_history)",
      "Read(~/.bash_history)",
      "Read(~/Library/Keychains/*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": []
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "refreshInterval": 5
  },
  "enabledPlugins": {
    "codex@openai-codex": true,
    "context7@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "index.crates.io"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "~/.local/cargo",
        "~/.local/go",
        "~/Library/Caches/Mozilla.sccache"
      ],
      "denyWrite": [
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.kube",
        "~/.config/gh"
      ],
      "denyRead": [
        ".env",
        ".env.*",
        "~/.ssh",
        "~/.gnupg",
        "~/.aws",
        "~/.kube",
        "~/.docker/config.json",
        "~/.config/gh",
        "~/.config/gcloud",
        "~/.git-credentials",
        "~/.netrc",
        "~/.npmrc",
        "~/.pypirc",
        "~/.local/cargo/credentials.toml",
        "~/.zsh_history",
        "~/.bash_history",
        "~/.node_repl_history",
        "~/.python_history",
        "~/Library/Keychains"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "docker",
      "cargo",
      "go"
    ]
  },
  "effortLevel": "high",
  "voiceEnabled": false,
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}

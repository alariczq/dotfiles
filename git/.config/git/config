[user]
  email = imzhongqi@gmail.com
  name = vika

[url "git@github.com:"]
  insteadof = https://github.com/

[init]
  defaultBranch = main

[core]
  editor = vim
  pager = delta
  untrackedcache = true
  fsmonitor = false

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  dark = true
  tabs = 4
  syntax-theme = Catppuccin Mocha
  file-style = "#cba6f7 bold"
  file-decoration-style = "#45475a ul"
  ; file-added-label = ""
  ; file-removed-label = ""
  ; file-modified-label = ""
  ; file-renamed-label = ""
  ; file-copied-label = ""
  hunk-header-style = omit
  minus-style = "syntax #4a2940"
  minus-emph-style = "bold syntax #6e3a5e"
  plus-style = "syntax #2b463f"
  plus-emph-style = "bold syntax #3e6357"
  line-numbers = true
  line-numbers-left-format = "{nm:>3}"
  line-numbers-right-format = "{np:>3}│ "
  line-numbers-left-style = "#585b70"
  line-numbers-right-style = "#585b70"
  line-numbers-minus-style = "#d77aa3 bold"
  line-numbers-plus-style = "#7ad9b0 bold"
  line-numbers-zero-style = "#585b70"

[merge]
  conflictstyle = zdiff3
[feature]
  manyFiles = true

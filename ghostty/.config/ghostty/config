# ===== Theme =====
theme = "Catppuccin Mocha"

# ===== Font =====
font-family = "Maple Mono NF CN Medium"
font-size = 15
font-thicken = false
font-codepoint-map = U+25B0-U+25B1=Menlo
adjust-cell-height = 20%

# ===== Window =====
window-padding-x = 10
window-padding-y = 8
window-padding-balance = true
macos-titlebar-style = tabs
macos-icon = xray
macos-titlebar-proxy-icon = hidden
window-save-state = always

# ===== Visual Effects =====
background-opacity = 0.86
background-blur = true
# Removes the dark fringing around glyphs that `native` shows on a transparent
# background. Available since 1.1.0.
alpha-blending = linear-corrected
unfocused-split-opacity = 1
minimum-contrast = 1.1

# ===== Cursor =====
cursor-style = block
cursor-style-blink = true
# Block cursor inverts using the current cell's colors, so the cursor adapts to
# colored text instead of using the theme's fixed accent. Available since 1.2.0.
cursor-color = cell-foreground
cursor-text = cell-background

# ===== Mouse & Links =====
mouse-hide-while-typing = true
link-url = true

# ===== Clipboard =====
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true

# ===== Shell Integration =====
shell-integration = detect
shell-integration-features = no-cursor,sudo,title,ssh-terminfo,ssh-env,path

# ===== Quick Terminal =====
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-size = 40%
quick-terminal-animation-duration = 0
quick-terminal-autohide = true

# ===== Behavior =====
confirm-close-surface = false
macos-option-as-alt = true
scrollback-limit = 100000000

# ===== Performance =====
window-vsync = false

# ===== Keybindings =====
# super+d=new_split:right and super+shift+enter=toggle_split_zoom are already
# the built-in defaults, so only the custom global binding is listed here.
keybind = global:cmd+backslash=toggle_quick_terminal
